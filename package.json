{
  "name": "chat-framework",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "bin": {
    "chat-framework": "src/cli.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build": "node src/build.js examples/chat.md dist/index.html",
    "build:paper": "node src/build.js examples/chat-paper.md dist/paper.html",
    "build:iterms": "node src/build.js examples/chat-iterms.md dist/iterms.html",
    "build:folder": "node src/build-folder.js examples/multi dist/wechat-hub.html",
    "build:showcase": "node src/build-folder.js examples/showcase dist/showcase-wechat-hub.html",
    "build:stage-gap": "node src/build-folder.js examples/stage-gap dist/stage-gap.html",
    "build:document:characters": "node src/build-document.js examples/documents/characters.yml dist/documents/characters.html",
    "build:document:settings": "node src/build-document.js examples/documents/settings.yml dist/documents/settings.html",
    "build:document:timeline": "node src/build-document.js examples/documents/timeline.yml dist/documents/timeline.html",
    "studio:dev": "vite --config studio/vite.config.ts",
    "studio:build": "vite build --config studio/vite.config.ts",
    "studio:preview": "vite preview --config studio/vite.config.ts",
    "req:gen": "bash scripts/generate-requirement-doc.sh",
    "req:check": "bash scripts/check-doc-sync.sh",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "js-yaml": "^3.14.2",
    "jszip": "^3.10.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "markdown-it": "^14.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^5.0.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
